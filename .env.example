# Copy this file to .env and fill in real values. .env is gitignored.
# Source into your shell before running dbt:
#   set -a && source .env && set +a

# ─── dbt ──────────────────────────────────────────────────────────────────
# Absolute path to the dbt/ directory containing profiles.yml.
# Must be absolute, not relative — relative paths break when `cd`-ing into dbt/.
DBT_PROFILES_DIR=/absolute/path/to/repo/dbt

# Default target when running `dbt build` without --target. Keep as dev locally.
DBT_TARGET=dev

# Your personal dev schema (one per developer). Convention: dev_<firstinitiallastname>
DBT_SCHEMA=dev_david

# ─── BigQuery (dev + ci) ──────────────────────────────────────────────────
GCP_PROJECT_ID_DEV=dee-data-ops

# Absolute path to the dev service account JSON keyfile.
# Created by Phase 0; should live OUTSIDE the repo.
BQ_KEYFILE_PATH=/Users/david/.config/gcloud/dee-data-ops/dbt-dev.json

# ─── BigQuery (prod) ──────────────────────────────────────────────────────
# Only used by CI/deploy workflows — local `dbt --target prod` is blocked by
# a Claude Code hook (see Phase 6).
GCP_PROJECT_ID_PROD=dee-data-ops-prod

# Path to prod SA keyfile. Populated in Phase 6 when the prod SA is created.
BQ_KEYFILE_PATH_PROD=

# ─── GoHighLevel (custom extractor) ───────────────────────────────────────
# Private Integration Token from the GHL sub-account (Settings → Private Integrations).
# v2 tokens are location-scoped, so GHL_LOCATION_ID must match the location the token
# was minted for. Used by ingestion/ghl/extract.py.
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── Fanbasis (custom extractor) ──────────────────────────────────────────
# Used by ingestion/fanbasis/extract.py. CSV-export fallback documented in that README.
FANBASIS_API_KEY=
