# Copy this file to .env and fill in real values. .env is gitignored.
# Source into your shell before running dbt:
#   set -a && source .env && set +a

# ─── dbt ──────────────────────────────────────────────────────────────────
# Absolute path to the dbt/ directory containing profiles.yml.
# Must be absolute, not relative — relative paths break when `cd`-ing into dbt/.
DBT_PROFILES_DIR=/absolute/path/to/repo/dbt

# Default target when running `dbt build` without --target. Keep as dev locally.
DBT_TARGET=dev

# Your personal dev schema (one per developer). Convention: dev_<firstinitiallastname>
DBT_SCHEMA=dev_david

# ─── BigQuery (dev + ci) ──────────────────────────────────────────────────
# Post-U2 retarget (2026-04-23): dev/ci/prod all point at the consolidated
# project `project-41542e21-470f-4589-96d`. Legacy `dee-data-ops` +
# `dee-data-ops-prod` are decommissioned at U14.
GCP_PROJECT_ID_DEV=project-41542e21-470f-4589-96d

# Absolute path to the dev service account JSON keyfile.
# Created by Phase 0; should live OUTSIDE the repo.
BQ_KEYFILE_PATH=/Users/david/.config/gcloud/project-41542e21-470f-4589-96d/dbt-dev.json

# Overrides the ci target's dataset. Set by the dbt-ci workflow to
# ci_pr_<num> so each PR builds into an isolated schema that is dropped
# on PR close. Local runs can leave this unset (falls back to "ci").
DBT_CI_SCHEMA=ci

# ─── BigQuery (prod) ──────────────────────────────────────────────────────
# Only used by CI/deploy workflows — local `dbt --target prod` is blocked by
# a Claude Code hook (see Phase 6). Points at the consolidated project
# post-U2 retarget; same project as GCP_PROJECT_ID_DEV during transition.
GCP_PROJECT_ID_PROD=project-41542e21-470f-4589-96d

# Path to prod SA keyfile. Populated by CI via the GCP_SA_KEY_PROD secret
# (a service-account key for `project-41542e21-470f-4589-96d` with BQ
# Data Editor on the working datasets + BQ Job User on the project).
BQ_KEYFILE_PATH_PROD=

# ─── GoHighLevel (custom extractor) ───────────────────────────────────────
# Private Integration Token from the GHL sub-account (Settings → Private Integrations).
# v2 tokens are location-scoped, so GHL_LOCATION_ID must match the location the token
# was minted for. Used by ingestion/ghl/extract.py.
#
# Secrets model (Track J, 2026-04-20):
#   - LOCAL DEV: set the raw values below; leave GCP_SECRET_MANAGER_PROJECT unset.
#   - CI / PROD: ingest.yml sets GCP_SECRET_MANAGER_PROJECT=project-41542e21-470f-4589-96d; the
#     extractor fetches the following Secret Manager secrets at runtime:
#         ghl-api-key       ← GHL_API_KEY
#         ghl-location-id   ← GHL_LOCATION_ID
#     (granted to the GH Actions SA via roles/secretmanager.secretAccessor)
GHL_API_KEY=
GHL_LOCATION_ID=

# Unset locally. CI sets this to the GCP project hosting the prod secrets.
# When set, ingestion/ghl/extract.py prefers Secret Manager over env vars.
# GCP_SECRET_MANAGER_PROJECT=

# ─── Fanbasis (custom extractor) ──────────────────────────────────────────
# Used by ingestion/fanbasis/extract.py. CSV-export fallback documented in that README.
FANBASIS_API_KEY=
