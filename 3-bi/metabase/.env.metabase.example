# Copy to .env.metabase and fill in. Gitignored.
# Authoring scripts read this via `set -a && source ops/metabase/.env.metabase && set +a`.
#
# ⚠️ DO NOT put secrets in this file. The API key is fetched from GCP Secret
# Manager at runtime — see ops/metabase/authoring/client.py. This file is for
# NON-SECRET configuration only (URL, flags, etc.).

# Public URL of the prod Metabase instance.
# `terraform output metabase_url` prints this.
MB_URL=https://XX-XX-XX-XX.nip.io

# Comma-separated list of email addresses that receive the weekly
# Speed-to-Lead digest. Populated by David; not committed. PII — stays in
# the gitignored .env.metabase, never in the repo.
# dashboard_subscriptions.py fails loudly if this is unset.
STL_WEEKLY_DIGEST_RECIPIENTS=
