# Copy to .env.metabase and fill in. Gitignored.
# Authoring scripts read these via `set -a && source .env.metabase && set +a`.

# Public URL of the prod Metabase instance.
# `terraform output metabase_url` prints this.
MB_URL=https://XX-XX-XX-XX.nip.io

# API key created in Admin → Authentication → API Keys, scope Admin.
MB_SESSION=mb_api_key_xxxxxxxxxxxxxxxxxxxxxxxxxx
