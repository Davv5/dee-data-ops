# Pipeline triage config — template
#
# Copy this file to `ops/env/triage/<source>.env` and fill in the values.
# `run_pipeline_triage.sh` reads the per-source config; `run_pipeline_triage_all.sh`
# iterates over every `*.env` file in this directory (excluding `_template.env`).
#
# What triage checks: Cloud Run revision health, secret availability + newline
# guardrails, env wiring, raw/core row counts, scheduler status, optional ingest
# smoke. Auto-runs on `validate_marts.sh` failure and on `run_pipeline.sh` ERR.
#
# All variables below are read by `run_pipeline_triage.sh`. Lines may be commented
# out — the script tolerates missing optional values and skips the corresponding
# checks.

# ---- Required ----

# GCP project. Falls back to GCP_PROJECT_ID env if unset.
TRIAGE_PROJECT_ID=project-41542e21-470f-4589-96d

# ---- Optional ----

# Cloud Run region. Default: us-central1.
TRIAGE_REGION=us-central1

# Cloud Run service to describe. Default: bq-ingest.
TRIAGE_SERVICE=bq-ingest

# Endpoint to hit for `--smoke` runs (e.g. /ingest-calendly, /ingest-fathom).
# Omit to skip smoke checks.
TRIAGE_INGEST_PATH=

# Cloud Scheduler job name (e.g. calendly-hourly-ingest). Triage describes the
# job and reads the latest AttemptFinished log entry. Omit to skip.
TRIAGE_SCHEDULER_JOB=

# Comma-separated qualified table names to row-count check. Pattern:
# `Dataset.table` (the script prepends the project). Triage reports per-table
# counts and rolls up to a single RAW_NONZERO / CORE_NONZERO signal.
TRIAGE_RAW_TABLES_CSV=
TRIAGE_CORE_TABLES_CSV=

# Secret Manager secret name (e.g. ghl-api-key, CalendlyApiKey). Triage
# verifies the latest version is accessible, non-empty, and not newline-padded.
TRIAGE_SECRET_NAME=

# Cloud Run env var that should bind to TRIAGE_SECRET_NAME (e.g. GHL_API_KEY).
# Triage verifies the env-var → secret wiring on the service spec.
TRIAGE_SECRET_ENV_VAR=

# Smoke-test timeout in seconds. Default: 90.
TRIAGE_SMOKE_TIMEOUT_SEC=90
